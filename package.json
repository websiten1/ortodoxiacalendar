{
  "name": "parohia-mea",
  "version": "0.1.0",
  "private": true,
  "description": "Scaffold initial pentru proiectul Parohia Mea + import calendar Patriarhia",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @parohia-mea/web",
    "dev:mobile": "npm run start --workspace @parohia-mea/mobile",
    "build:web": "npm run build --workspace @parohia-mea/web",
    "fetch:calendar": "node ./scripts/fetch-patriarhia-calendar.mjs",
    "seed:calendar:sql": "node ./scripts/generate-sarbatori-seed.mjs"
  },
  "overrides": {
    "react-native": "0.81.5"
  }
}
